<Window
    x:Class="SpotifyWidget.Controls.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Settings">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            Text="Widget Settings"
            Style="{StaticResource TitleTextBlockStyle}"
            Margin="0,0,0,16" />

        <!-- Spotify Client ID -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Spotify Client ID" Style="{StaticResource CaptionTextBlockStyle}" />
            <TextBox x:Name="ClientIdTextBox" PlaceholderText="Enter your Spotify Client ID" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Theme -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Theme" Style="{StaticResource CaptionTextBlockStyle}" />
            <ComboBox x:Name="ThemeCombo" Margin="0,4,0,0">
                <ComboBoxItem Content="System" />
                <ComboBoxItem Content="Light" />
                <ComboBoxItem Content="Dark" />
            </ComboBox>
        </StackPanel>

        <!-- Refresh Interval -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Refresh Interval (ms)" Style="{StaticResource CaptionTextBlockStyle}" />
            <TextBox x:Name="RefreshIntervalTextBox" PlaceholderText="1000" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Opacity -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="Widget Opacity" Style="{StaticResource CaptionTextBlockStyle}" />
            <Slider x:Name="OpacitySlider" Minimum="0.1" Maximum="1.0" StepFrequency="0.1" Value="1.0" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Always on Top -->
        <CheckBox x:Name="AlwaysOnTopCheckbox" Grid.Row="5" Content="Always on Top" Margin="0,0,0,12" />

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button x:Name="CancelButton" Content="Cancel" Click="CancelButton_Click" />
            <Button x:Name="SaveButton" Content="Save" Style="{StaticResource AccentButtonStyle}" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Window>