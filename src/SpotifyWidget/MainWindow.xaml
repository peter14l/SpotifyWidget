<Window
    x:Class="SpotifyWidget.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SpotifyWidget"
    xmlns:controls="using:SpotifyWidget.Controls"
    Title="Spotify Widget">

    <Grid x:Name="RootGrid" Background="Transparent" Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="Spotify"
                Style="{StaticResource TitleTextBlockStyle}"
                VerticalAlignment="Center" />

            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button
                    Content="&#xE713;"
                    Style="{StaticResource SymbolButtonStyle}"
                    Click="SettingsButton_Click" />
                <Button
                    Content="&#xE8BB;"
                    Style="{StaticResource SymbolButtonStyle}"
                    Click="CloseButton_Click" />
            </StackPanel>
        </Grid>

        <!-- Player Content -->
        <controls:SpotifyPlayerControl
            Grid.Row="1"
            x:Name="PlayerControl" />

        <!-- Status Bar -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                VerticalAlignment="Center" />
        </Grid>
    </Grid>
</Window>